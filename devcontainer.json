{
  "name": "forensic-transcription-pipeline",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.11-bookworm",

  // Codespaces machine type: 4-core/16GB recommended minimum for testing
  // large-v3-turbo comfortably. 2-core/8GB (free tier default) works with
  // the "small"/"medium" test models set in .devcontainer/setup.sh.
  "hostRequirements": {
    "cpus": 4,
    "memory": "16gb"
  },

  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {}
  },

  "postCreateCommand": "bash .devcontainer/setup.sh",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  "remoteEnv": {
    "PIPELINE_TEST_MODE": "1"
  }
}
